{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://panopticon.local/schemas/panopticon-event.schema.json",
  "title": "PanopticonEventEnvelope",
  "type": "object",
  "required": [
    "event_id",
    "layer",
    "event_type",
    "event_ts",
    "ingest_ts_utc",
    "source",
    "version_tag",
    "payload"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "description": "UUIDv7 style event identifier"
    },
    "layer": {
      "type": "string",
      "enum": ["L1", "L2", "L3", "L4", "L5"]
    },
    "event_type": {
      "type": "string"
    },
    "event_ts": {
      "type": "string",
      "format": "date-time"
    },
    "ingest_ts_utc": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "string"
    },
    "source_event_id": {
      "type": ["string", "null"]
    },
    "version_tag": {
      "type": "string",
      "description": "codeHash:configHash:modelId"
    },
    "market_id": {
      "type": ["string", "null"]
    },
    "asset_id": {
      "type": ["string", "null"]
    },
    "payload": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
